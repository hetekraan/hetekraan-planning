{
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/book(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    },
    {
      "source": "/book.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/book/:token", "destination": "/book.html?token=:token" }
  ],
  "crons": [
    {
      "path": "/api/cron/daily-analysis",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/morning-messages",
      "schedule": "0 6 * * *"
    }
  ],
  "functions": {
    "api/cron/daily-analysis.js": {
      "maxDuration": 300
    }
  }
}
