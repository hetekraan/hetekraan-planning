{
  "framework": null,
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/book/:token",
      "destination": "/book?token=:token",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/book(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    },
    {
      "source": "/book.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate, max-age=0" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate, max-age=0" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/daily-analysis",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/morning-messages",
      "schedule": "0 6 * * *"
    }
  ],
  "functions": {
    "api/cron/daily-analysis.js": {
      "maxDuration": 60
    }
  }
}
