# Kopieer naar .env.local (lokaal) of zet in Vercel → Settings → Environment Variables.
# Waarden na nieuwe kalender in GHL — zie projectdocumentatie of support GHL.

GHL_API_KEY=
GHL_LOCATION_ID=
# Productie-kalender (fallback in code als deze regel leeg blijft: yfKaXxKvbNvMaibmgxYQ)
GHL_CALENDAR_ID=yfKaXxKvbNvMaibmgxYQ
# Optioneel: apart technisch custom field voor booking token (zichtbare field kan dan leesbaar blijven)
# BOOKING_TECH_TOKEN_FIELD_ID=

# Aanbevolen: user UUID = degene die aan de planning-kalender in GHL hangt. Zelfde id voor POST block-slots,
# GET blocked-slots en availability (zonder dit pakt de code de kalender-user of vaste fallback).
# GHL_BLOCK_SLOT_USER_ID=
# GHL_APPOINTMENT_ASSIGNED_USER_ID=
# Optioneel: expliciet voor GET …/free-slots (sommige kalendertypes); anders zelfde als boven
# GHL_FREE_SLOTS_USER_ID=

SESSION_SECRET=
GOOGLE_MAPS_API_KEY=
BASE_URL=
